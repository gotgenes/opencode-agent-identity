{
  "name": "@gotgenes/opencode-agent-identity",
  "version": "2.1.1",
  "description": "OpenCode plugins for agent self-identity and per-message agent attribution",
  "author": {
    "name": "Chris Lasher"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "MIGRATION.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm && bun run build:types",
    "build:types": "tsc --project tsconfig.build.json --noEmitOnError false",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:md": "markdownlint-cli2 '*.md'",
    "lint:all": "bun run lint && bun run lint:md",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "agent",
    "identity",
    "attribution"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gotgenes/opencode-agent-identity.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@opencode-ai/sdk": "^1.2.18",
    "bun-types": "latest",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^5.7.3"
  }
}
