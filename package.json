{
  "name": "@gotgenes/opencode-agent-identity",
  "version": "0.1.0",
  "description": "OpenCode plugins for agent self-identity and per-message agent attribution",
  "author": {
    "name": "Chris Lasher"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm && bun run build:types",
    "build:types": "tsc --project tsconfig.build.json --noEmitOnError false",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "agent",
    "identity",
    "attribution"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gotgenes/opencode-agent-identity.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.2.16"
  },
  "devDependencies": {
    "@opencode-ai/sdk": "^1.2.16",
    "bun-types": "latest",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
